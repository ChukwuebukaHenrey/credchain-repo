# CredChain UI (v2) — environment
# All optional in development; the Vite dev proxy forwards /api → localhost:5000.

# Data mode: live backend by default. Set to "true" for backend-less design work
# (in-browser fixtures, no server needed).
VITE_USE_MOCK=false

# Backend base URL for production builds (dev uses the /api proxy instead).
# VITE_API_BASE_URL=https://api.credchain.example/api

# Backend origin the Vite dev proxy targets (default http://localhost:5000).
# VITE_API_TARGET=http://localhost:5000

# Socket.io origin (defaults to http://localhost:5000).
# VITE_SOCKET_URL=http://localhost:5000
