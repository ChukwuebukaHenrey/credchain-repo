# CredChain — AI CV Engine environment
# Copy to ".env" (git-ignored) for local dev, or set these in Railway for prod.

# Production CORS: comma-separated extra origins to allow (the localhost
# origins are always included). e.g. https://credchain-backend.up.railway.app
ALLOWED_ORIGINS=

# Railway injects PORT automatically; locally we default to 8001.
# PORT=8001
