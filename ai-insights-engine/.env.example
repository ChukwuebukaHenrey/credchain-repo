# CredChain — AI Insights Engine environment
# Copy to ".env" (git-ignored) for local dev, or set these in Railway for prod.

# OpenAI API key. WITHOUT this the service still runs and returns the safe
# empty {strong_skills, career_paths, next_steps} template (never crashes).
OPENAI_API_KEY=

# Production CORS: comma-separated extra origins to allow (the localhost
# origins are always included). e.g. https://credchain.vercel.app,https://credchain-backend.up.railway.app
ALLOWED_ORIGINS=

# Railway injects PORT automatically; locally we default to 8002.
# PORT=8002
